<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
             x:Class="AndroidTriviaGame.Views.GameView"
             xmlns:vm="using:AndroidTriviaGame.ViewModels"
             x:DataType="vm:GameViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <StackPanel Grid.Row="0" Margin="16,16,16,8" Spacing="10">
            
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Content="Leave" Background="#FF4444" 
                        Foreground="White" FontWeight="Bold" CornerRadius="8"
                        Command="{Binding LeaveCommand}"/>
                
                <TextBlock Grid.Column="2" Text="{Binding QuestionProgress}" 
                           VerticalAlignment="Center"
                           FontSize="20" FontWeight="Bold" />
            </Grid>

            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding Player1Text}" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,15,0" />
                <TextBlock Text="{Binding Player2Text}" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,15,0" />
                <TextBlock Text="{Binding Player3Text}" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,15,0" />
                <TextBlock Text="{Binding Player4Text}" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" />
            </WrapPanel>
            
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,10,20,20" RowDefinitions="Auto, *, Auto" IsVisible="{Binding !IsGameOver}">
            
            <TextBlock Grid.Row="0" Text="{Binding CurrentQuestionText}" 
                       FontSize="{DynamicResource QuestionFontSize}" 
                       FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" 
                       Margin="0, 10, 0, 20"/>

            <ListBox Grid.Row="1" ItemsSource="{Binding CurrentAnswers}" 
                     SelectedIndex="{Binding SelectedAnswerIndex}"
                     IsEnabled="{Binding !HasSubmittedAnswer}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0, 0, 0, 20">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                                CornerRadius="8" Padding="15" Margin="0,6">
                                
                            <TextBlock Text="{Binding}" 
                                       FontSize="{DynamicResource AnswerFontSize}" 
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="Submit Answer" 
                    Command="{Binding SubmitAnswerCommand}"
                    IsEnabled="{Binding !HasSubmittedAnswer}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#4CAF50" Foreground="White" 
                    FontSize="20" FontWeight="Bold" Padding="15" CornerRadius="8"/>
        </Grid>

        <Grid Grid.Row="1" Margin="20" IsVisible="{Binding IsGameOver}">
            <StackPanel VerticalAlignment="Center" Spacing="20">
                
                <TextBlock Text="Game Over!" FontSize="36" FontWeight="Black" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Final Scores:" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="{Binding Player1Text}" FontSize="24" FontWeight="Black" Foreground="#4CAF50" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Player2Text}" FontSize="24" FontWeight="Black" Foreground="#4CAF50" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Player3Text}" FontSize="24" FontWeight="Black" Foreground="#4CAF50" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Player4Text}" FontSize="24" FontWeight="Black" Foreground="#4CAF50" HorizontalAlignment="Center" />
                </StackPanel>
                
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>