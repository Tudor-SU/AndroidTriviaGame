
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AndroidTriviaGame.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AndroidTriviaGame.Views"
        
        mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
        x:Class="AndroidTriviaGame.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AndroidTriviaGame"
        Width="360"
        Height="800">
        
    <views:MainView />
    
    
</Window>