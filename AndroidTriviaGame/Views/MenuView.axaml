<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
             x:Class="AndroidTriviaGame.Views.MenuView"
             xmlns:vm="using:AndroidTriviaGame.ViewModels"
             x:DataType="vm:MenuViewModel"
             >
    
    <Grid Background="#121214">
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="32" Margin="24">
            
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                
                <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <StackPanel Spacing="16" Margin="0,20,0,0">
                
                <Button Content="Play Game" 
                        Height="56" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        FontSize="18" 
                        FontWeight="Bold" 
                        Foreground="White" 
                        Background="#7C4DFF" 
                        CornerRadius="8"
                        Command="{Binding PlayCommand}"/>

                <Button Content="Settings" 
                        Height="48" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        FontSize="16" 
                        FontWeight="SemiBold" 
                        Foreground="White" 
                        Background="#1A1A1E" 
                        BorderBrush="#29292E"
                        BorderThickness="1"
                        CornerRadius="8"/>
                        <!-- Command="{Binding SettingsCommand}"/> -->

                <Button Content="Exit" 
                        Height="48" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        FontSize="16" 
                        FontWeight="Bold" 
                        Foreground="#EF4444" 
                        Background="#1A1A1E" 
                        BorderBrush="#29292E"
                        CornerRadius="8"/>
                        <!-- Command="{Binding ExitCommand}"/> -->
                
            </StackPanel>
            
        </StackPanel>
    </Grid>

    
    
    
</UserControl>
