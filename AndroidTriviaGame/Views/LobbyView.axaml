<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AndroidTriviaGame.ViewModels"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
             x:Class="AndroidTriviaGame.Views.LobbyView"
             x:DataType="vm:LobbyViewModel">
    
    <Grid>
    
        <Grid VerticalAlignment="Top" Margin="16,16,16,0" ColumnDefinitions="Auto, *, Auto">
            
            <Button Grid.Column="0"
                    Content="Leave Room"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="#EF4444"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    Command="{Binding LeaveCommand}"/>
    
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Room:" Opacity="0.7" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RoomCode}" Foreground="#7C4DFF" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="24" Margin="24">
    
            <StackPanel HorizontalAlignment="Center" Spacing="6">
                <TextBlock Text="Waiting for Players..." FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding Players.Count}" Foreground="#7C4DFF" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="/ 4 Players" Opacity="0.7" FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
            </StackPanel>
    
            <Border BorderBrush="Gray" Opacity="0.8" BorderThickness="1" CornerRadius="12" Padding="8">
                <ItemsControl ItemsSource="{Binding Players}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnDefinitions="Auto, *" Margin="4,6">
                                <TextBlock Grid.Column="0" Text="👤" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
    
            <Button Content="Start Game 🚀"
                    Height="56"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#7C4DFF"
                    CornerRadius="8"
                    Margin="0,12,0,0"
                    IsVisible="{Binding IsHost}"
                    Command="{Binding StartCommand}"/>
    
        </StackPanel>
    </Grid>
</UserControl>