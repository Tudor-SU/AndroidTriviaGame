<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AndroidTriviaGame.ViewModels"
             xmlns:views="clr-namespace:AndroidTriviaGame.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AndroidTriviaGame.Views.MainView"
             x:DataType="viewModels:MainWindowViewModel"> <UserControl.DataTemplates>
       
        <DataTemplate DataType="viewModels:LoginViewModel">
            <views:LoginView/>
        </DataTemplate>
        
        <DataTemplate DataType="viewModels:MenuViewModel">
            <views:MenuView/>
        </DataTemplate>
        
        <DataTemplate DataType="viewModels:JoinLobbyViewModel">
            <views:JoinLobbyView/>
        </DataTemplate>
        
        <DataTemplate DataType="viewModels:CreateLobbyViewModel">
            <views:CreateLobbyView/>
        </DataTemplate>
        
        <DataTemplate DataType="viewModels:RegisterViewModel">
            <views:RegisterView/>
        </DataTemplate>
        
        <DataTemplate DataType="viewModels:LobbyViewModel">
            <views:LobbyView/>
        </DataTemplate>


    </UserControl.DataTemplates> <ContentControl Content="{Binding CurrentPage}" />
</UserControl>