<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AndroidTriviaGame.ViewModels"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
             x:Class="AndroidTriviaGame.Views.JoinLobbyView"
             x:DataType="vm:JoinLobbyViewModel">
    
    <Grid>
        
        <Grid VerticalAlignment="Top" Margin="16,16,16,0" ColumnDefinitions="Auto, *, Auto">
            
            <Button Grid.Column="0"
                    Content="← Back" 
                    FontSize="16"
                    FontWeight="SemiBold"
                    Background="Transparent" 
                    BorderThickness="0"
                    Padding="8"
                    Command="{Binding BackCommand}"/>

            <Button Grid.Column="2"
                    Content="Create Lobby" 
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#7C4DFF" 
                    Background="Transparent" 
                    BorderThickness="0"
                    Padding="8"
                    Command="{Binding CreateLobbyCommand}"/>
            
        </Grid>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="24" Margin="32">
            
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="🚪" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Join Lobby" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ErrMsg}" FontSize="14" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                
                
            </StackPanel>

            <TextBox Text="{Binding LobbyCode}"
                     PlaceholderText="Enter Code" 
                     FontSize="24" 
                     FontWeight="Bold"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     Height="64" 
                     CornerRadius="8"
                     BorderThickness="1"
                     SelectionBrush="#7C4DFF"
                     Margin="0,16,0,0"
                     Foreground="{DynamicResource TextControlForeground}" />

            <StackPanel Spacing="16" Margin="0,16,0,0">
                <Button Content="Join" 
                        Height="56" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        FontSize="18" 
                        FontWeight="Bold" 
                        Foreground="White" 
                        Background="#7C4DFF" 
                        CornerRadius="8"
                        Command="{Binding JoinCommand}"/>
            </StackPanel>
            
        </StackPanel>
    </Grid>
</UserControl>